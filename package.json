{
  "name": "crow-social-collector",
  "description": "Cloudflare Worker that collects social media posts from platform APIs and stores raw data in R2",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8018",
    "deploy": "wrangler deploy --minify --env production",
    "deploy:dev": "wrangler deploy --minify --env dev",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "bun run prettier src/ --write",
    "db:migrate:local": "wrangler d1 migrations apply DB",
    "db:migrate:dev": "wrangler d1 migrations apply DB --env dev --remote",
    "db:migrate:prod": "wrangler d1 migrations apply DB --env production --remote"
  },
  "dependencies": {
    "@antfu/eslint-config": "^6.7.1",
    "@hono/swagger-ui": "^0.5.2",
    "@hono/zod-openapi": "^1.1.5",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.1",
    "jiti": "^2.6.1",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240124.0",
    "@commitlint/config-conventional": "^20.2.0",
    "drizzle-kit": "^0.31.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "wrangler": "^4.55.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
